# J.A.R.V.I.S. Environment Configuration

# --- THE BRAIN (LLM & Orchestration) ---
# Primary Engine: Google AI Studio (1M context window, high limits on free tier)
# Get your API key at: https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"

# Fast Engine: Groq Cloud (Lowest latency, best for real-time voice, Llama 3.3/Mixtral)
# Get your API key at: https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# Fallback/Router Engine: OpenRouter (Access to 20+ free models with one key)
# Get your API key at: https://openrouter.ai/
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# --- THE VOICE (Text-to-Speech) ---
# High Quality Voice Engine: ElevenLabs (Cinematic quality, free tier available)
# Get your API key at: https://elevenlabs.io/
ELEVENLABS_API_KEY="your_elevenlabs_api_key_here"
# If using ElevenLabs, specify the voice ID (e.g., the closest one to Paul Bettany)
# ELEVENLABS_VOICE_ID="your_voice_id_here"

# Active Model Selection
# Choose which brain to use for the cognitive filter: "gemini", "groq", or "openrouter"
ACTIVE_BRAIN_ENGINE="gemini"

# Choose which TTS to use: "mac_say" (free, zero latency), "elevenlabs" (cinematic), or "kokoro" (local)
ACTIVE_TTS_ENGINE="mac_say"
